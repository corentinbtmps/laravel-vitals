{
    "name": "humantocomputer/laravel-vitals",
    "description": "GTMetrix-style Lighthouse audits combined with backend telemetry and host-app source pointers, for Laravel 11/12/13.",
    "keywords": [
        "laravel",
        "lighthouse",
        "performance",
        "core-web-vitals",
        "audit",
        "pagespeed"
    ],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/slack-notification-channel": "^3.0",
        "livewire/livewire": "^4.0",
        "livewire/flux": "^2.0",
        "nikic/php-parser": "^5.0",
        "spatie/laravel-package-tools": "^1.16",
        "symfony/process": "^7.0|^8.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "rector/rector": "^2.0"
    },
    "suggest": {
        "livewire/flux-pro": "Enables richer chart components in the dashboard (^3.0)"
    },
    "autoload": {
        "psr-4": {
            "LaravelVitals\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelVitals\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": [
            "@php vendor/bin/phpstan analyse",
            "@php vendor/bin/rector process --dry-run"
        ],
        "test": "@php vendor/bin/pest",
        "test-coverage": "@php vendor/bin/pest --coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelVitals\\VitalsServiceProvider"
            ],
            "aliases": {
                "Vitals": "LaravelVitals\\Facades\\Vitals"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}